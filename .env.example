# MySQL
DATABASE_URL="mysql://USER:PASSWORD@localhost:3306/DATABASE"

# JWT — gere uma string aleatória longa
JWT_SECRET="troque-isto-por-uma-string-longa-e-aleatoria-em-producao"
JWT_EXPIRES_IN="30d"

# Servidor (Railway define PORT automaticamente)
PORT=4000
NODE_ENV=development

# CORS — URLs do frontend, separadas por vírgula
CORS_ORIGINS="http://localhost:5500,http://localhost:3000"

# Cookie (produção com HTTPS)
COOKIE_DOMAIN=""
COOKIE_SECURE=false
